# =============================================================================
# my.cnf - MySQL 8.0 Configuration for QuckApp Development
#
# Tuned for local Docker-based development. Mount this file into the
# container at /etc/mysql/conf.d/quckapp.cnf
#
# docker-compose example:
#   volumes:
#     - ./database/quckapp-mysql/docker/my.cnf:/etc/mysql/conf.d/quckapp.cnf:ro
# =============================================================================

[mysqld]
# --------------------------------------------------------------------------
# Character Set & Collation
# --------------------------------------------------------------------------
character-set-server       = utf8mb4
collation-server           = utf8mb4_unicode_ci
character-set-client-handshake = FALSE

# --------------------------------------------------------------------------
# InnoDB Settings
# --------------------------------------------------------------------------
default-storage-engine     = InnoDB
innodb_buffer_pool_size    = 256M
innodb_log_file_size       = 64M
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table      = 1
innodb_flush_method        = O_DIRECT
innodb_lock_wait_timeout   = 30
innodb_print_all_deadlocks = 1

# --------------------------------------------------------------------------
# General Performance
# --------------------------------------------------------------------------
max_connections            = 200
max_allowed_packet         = 64M
table_open_cache           = 400
thread_cache_size          = 16
tmp_table_size             = 64M
max_heap_table_size        = 64M

# --------------------------------------------------------------------------
# Query Tuning
# --------------------------------------------------------------------------
join_buffer_size           = 4M
sort_buffer_size           = 4M
read_buffer_size           = 2M
read_rnd_buffer_size       = 2M

# --------------------------------------------------------------------------
# Logging (development-friendly)
# --------------------------------------------------------------------------
general_log                = 0
slow_query_log             = 1
slow_query_log_file        = /var/log/mysql/slow-query.log
long_query_time            = 1
log_queries_not_using_indexes = 1
log_error_verbosity        = 2

# --------------------------------------------------------------------------
# Binary Logging (minimal for dev, enable properly for prod)
# --------------------------------------------------------------------------
skip-log-bin

# --------------------------------------------------------------------------
# Networking
# --------------------------------------------------------------------------
bind-address               = 0.0.0.0
port                       = 3306
mysqlx                     = 0

# --------------------------------------------------------------------------
# Timezone & SQL Mode
# --------------------------------------------------------------------------
default-time-zone          = '+00:00'
sql_mode                   = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# --------------------------------------------------------------------------
# Authentication (MySQL 8.0+)
# --------------------------------------------------------------------------
default_authentication_plugin = mysql_native_password

[mysql]
default-character-set      = utf8mb4

[client]
default-character-set      = utf8mb4
port                       = 3306
