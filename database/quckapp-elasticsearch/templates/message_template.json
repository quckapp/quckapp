{
  "index_patterns": ["message-*"],
  "priority": 100,
  "template": {
    "settings": {
      "index": {
        "number_of_shards": 3,
        "number_of_replicas": 1,
        "refresh_interval": "5s",
        "lifecycle": {
          "name": "message_lifecycle",
          "rollover_alias": "messages"
        }
      },
      "analysis": {
        "filter": {
          "autocomplete_filter": {
            "type": "edge_ngram",
            "min_gram": 2,
            "max_gram": 20
          },
          "english_stemmer": {
            "type": "stemmer",
            "language": "english"
          },
          "english_stop": {
            "type": "stop",
            "stopwords": "_english_"
          }
        },
        "analyzer": {
          "autocomplete_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "autocomplete_filter"]
          },
          "content_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "english_stop", "english_stemmer"]
          }
        }
      }
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "message_id": { "type": "keyword" },
        "content": {
          "type": "text",
          "analyzer": "content_analyzer",
          "search_analyzer": "standard",
          "fields": {
            "exact": { "type": "keyword", "ignore_above": 8191 }
          }
        },
        "sender_id": { "type": "keyword" },
        "channel_id": { "type": "keyword" },
        "workspace_id": { "type": "keyword" },
        "thread_id": { "type": "keyword" },
        "message_type": { "type": "keyword" },
        "created_at": {
          "type": "date",
          "format": "strict_date_optional_time||epoch_millis"
        },
        "updated_at": {
          "type": "date",
          "format": "strict_date_optional_time||epoch_millis"
        },
        "is_edited": { "type": "boolean" },
        "is_deleted": { "type": "boolean" },
        "attachments": {
          "type": "nested",
          "properties": {
            "file_id": { "type": "keyword" },
            "filename": {
              "type": "text",
              "fields": { "keyword": { "type": "keyword" } }
            },
            "mime_type": { "type": "keyword" },
            "size_bytes": { "type": "long" }
          }
        },
        "mentions": { "type": "keyword" },
        "reactions": {
          "type": "nested",
          "properties": {
            "emoji": { "type": "keyword" },
            "user_ids": { "type": "keyword" },
            "count": { "type": "integer" }
          }
        }
      }
    },
    "aliases": {}
  }
}
